{
  "version": 2,
  "functions": {
    "ai.js": { "runtime": "@vercel/node" },
    "api/items.js": { "runtime": "@vercel/node" },
    "api/search.js": { "runtime": "@vercel/node" }
  },
  "routes": [
    { "src": "/api/ai", "dest": "/ai.js" },
    { "src": "/api/items", "dest": "/api/items.js" },
    { "src": "/api/search", "dest": "/api/search.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
