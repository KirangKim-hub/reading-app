{
  "version": 2,
  "builds": [
    { "src": "ai.js", "use": "@vercel/node" },
    { "src": "api/items.js", "use": "@vercel/node" },
    { "src": "api/search.js", "use": "@vercel/node" },
    
    { "src": "app.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/ai", "dest": "/ai.js" },
    { "src": "/api/items", "dest": "/api/items.js" },
    { "src": "/api/search", "dest": "/api/search.js" },
    { "src": "/(.*)", "dest": "/app.html" }
  ]
}
